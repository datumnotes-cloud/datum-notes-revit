<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Options"
        Height="540"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F4F6"
        Foreground="#111111">
    <Window.Resources>
        <Style x:Key="ReadableComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
        </Style>
        <DataTemplate x:Key="ReadableComboItemTemplate">
            <TextBlock Text="{Binding}" Foreground="#000000" Background="#FFFFFF"/>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Datum Notes - Redline Export" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <TabControl Grid.Row="1">
            <TabItem Header="What to Include">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="includeProjectCheck" Content="Project name" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="includeDateCheck" Content="Date" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="includeRoomCheck" Content="Room numbers" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="includeAssignedCheck" Content="Assigned to" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="includeDueCheck" Content="Due dates" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="includeCompletedCheck" Content="Completed items" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="includeUncompletedCheck" Content="Uncompleted items" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="includeCategoryCheck" Content="Categories" IsChecked="True" Margin="0,0,0,4"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Filters">
                <StackPanel Margin="10">
                    <TextBlock Text="Filter by category" Margin="0,0,0,4"/>
                    <ComboBox x:Name="filterCategoryCombo" Margin="0,0,0,10" MinHeight="30" Background="#FFFFFF" Foreground="#000000" BorderBrush="#9CA3AF" ItemContainerStyle="{StaticResource ReadableComboItemStyle}" ItemTemplate="{StaticResource ReadableComboItemTemplate}"/>

                    <TextBlock Text="Filter by assigned to" Margin="0,0,0,4"/>
                    <ComboBox x:Name="filterAssignedCombo" Margin="0,0,0,10" MinHeight="30" Background="#FFFFFF" Foreground="#000000" BorderBrush="#9CA3AF" ItemContainerStyle="{StaticResource ReadableComboItemStyle}" ItemTemplate="{StaticResource ReadableComboItemTemplate}"/>

                    <TextBlock Text="Filter by date range (YYYY-MM-DD)" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="startDateText" Grid.Column="0" MinHeight="30" Background="#FFFFFF" Foreground="#000000" BorderBrush="#9CA3AF"/>
                        <TextBox x:Name="endDateText" Grid.Column="2" MinHeight="30" Background="#FFFFFF" Foreground="#000000" BorderBrush="#9CA3AF"/>
                    </Grid>

                    <TextBlock Text="Sort order" Margin="0,0,0,4"/>
                    <ComboBox x:Name="sortOrderCombo" Margin="0,0,0,0" MinHeight="30" Background="#FFFFFF" Foreground="#000000" BorderBrush="#9CA3AF" ItemContainerStyle="{StaticResource ReadableComboItemStyle}" ItemTemplate="{StaticResource ReadableComboItemTemplate}"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="cancelButton" Content="Cancel" Width="90" Height="32" Margin="0,0,8,0"/>
            <Button x:Name="okButton" Content="Apply" Width="90" Height="32" Background="#0F766E" Foreground="#FFFFFF" BorderBrush="#115E59"/>
        </StackPanel>
    </Grid>
</Window>
